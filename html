<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pranav Maram | Personal Website</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    background:linear-gradient(135deg,#0f172a,#1e293b);
    color:white;
    overflow-x:hidden;
}

.hero{
    height:100vh;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    text-align:center;
    padding:20px;
}

.hero h1{
    font-size:4rem;
    animation:slideDown 1s ease;
}

.hero p{
    font-size:1.2rem;
    max-width:700px;
    margin-top:15px;
    opacity:0;
    animation:fadeIn 1s ease forwards;
    animation-delay:.5s;
}

.highlight{
    color:#38bdf8;
}

.card-container{
    display:flex;
    justify-content:center;
    flex-wrap:wrap;
    gap:30px;
    padding:80px 20px;
}

.card{
    width:300px;
    background:rgba(255,255,255,0.08);
    backdrop-filter:blur(12px);
    border-radius:20px;
    padding:25px;
    transition:0.4s;
    opacity:0;
    transform:translateY(50px);
}

.card.show{
    opacity:1;
    transform:translateY(0);
}

.card:hover{
    transform:translateY(-10px) scale(1.03);
}

.card h2{
    color:#38bdf8;
    margin-bottom:15px;
}

.footer{
    text-align:center;
    padding:40px;
    opacity:.7;
}

@keyframes slideDown{
    from{
        opacity:0;
        transform:translateY(-50px);
    }
    to{
        opacity:1;
        transform:translateY(0);
    }
}

@keyframes fadeIn{
    from{
        opacity:0;
    }
    to{
        opacity:1;
    }
}
</style>
</head>
<body>

<section class="hero">
    <h1>Pranav <span class="highlight">Maram</span></h1>
    <p>
        Narcassist • Narcassist • Outro
        <br><br>
        Hi I'm Pranav Maram, a 15-year-old student at
        Shri Ram Global School OMR.
    </p>
</section>

<section class="card-container">
    <div class="card">
        <h2>Rajath is a poopy pants</h2>
        <p>
            He does big doodoo in pants
        </p>
    </div>

    <div class="card">
        <h2>Rajath likes pp</h2>
        <p>
           He likes touching small cock ayo
        </p>
    </div>

    <div class="card">
        <h2>fweah</h2>
        <p>
            • Rajath is wrong.<br>
            • I am a narcassist.<br>
          
        </p>
    </div>
</section>

<div class="footer">
    © 2026 Pranav Maram
</div>

<script>
const cards = document.querySelectorAll('.card');

const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
        if(entry.isIntersecting){
            entry.target.classList.add('show');
        }
    });
},{
    threshold:0.2
});

cards.forEach(card => observer.observe(card));
</script>

</body>
</html>
